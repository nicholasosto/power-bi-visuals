{
	"folders": [
		{
			"path": "."
		},
		{
			"name": "PBIR - PTO Report",
			"uri": "fabric:/workspaces/14fcb7ad-1cdd-41d3-a68d-d7778fc5d7ee/reports/2c163758-a8fb-450a-a697-ebaedc7c22ef"
		},
		{
			"name": "PBIR - Big Time Analytics",
			"uri": "fabric:/workspaces/df29397f-d097-46b5-adc1-ca0bef6fe595/reports/9d7b7067-e9d0-40d2-ae74-b899876cfd2f"
		},
		{
			"name": "Fabric - ACS - Operations - Invoicing Review",
			"uri": "fabric:/workspaces/14fcb7ad-1cdd-41d3-a68d-d7778fc5d7ee/Reports/Invoicing Review"
		}
	],
	"settings": {
		"python.defaultInterpreterPath": "e:/Astrix Code/power-bi-visuals/venv/Scripts/python.exe",
		"python.terminal.activateEnvironment": true,
		"python.analysis.typeCheckingMode": "off",
		"files.exclude": {
			"**/__pycache__": true,
			"**/*.pyc": true,
			"**/.pytest_cache": true
		},
		"mcp": {
			"servers": {
				"microsoft/fabric-rti-mcp": {
					"type": "stdio",
					"command": "uvx",
					"args": [
						"microsoft-fabric-rti-mcp@0.1.0"
					],
					"env": {
						"KUSTO_SERVICE_URI": "${input:kusto_service_uri}",
						"KUSTO_SERVICE_DEFAULT_DB": "${input:kusto_default_db}",
						"AZ_OPENAI_EMBEDDING_ENDPOINT": "${input:az_openai_embedding_endpoint}",
						"KUSTO_KNOWN_SERVICES": "${input:kusto_known_services_json}",
						"KUSTO_EAGER_CONNECT": "${input:kusto_eager_connect}",
						"KUSTO_ALLOW_UNKNOWN_SERVICES": "${input:kusto_allow_unknown_services}",
						"FABRIC_API_BASE": "${input:fabric_api_base}"
					},
					"gallery": "https://api.mcp.github.com",
					"version": "1.0.0"
				}
			},
			"inputs": [
				{
					"id": "kusto_service_uri",
					"type": "promptString",
					"description": "Default Kusto cluster URI (e.g., https://help.kusto.windows.net/ or your cluster).",
					"password": false
				},
				{
					"id": "kusto_default_db",
					"type": "promptString",
					"description": "Default database name for Kusto queries (e.g., Samples).",
					"password": false
				},
				{
					"id": "az_openai_embedding_endpoint",
					"type": "promptString",
					"description": "Azure OpenAI embeddings endpoint for shots/semantic search (format: https://<resource>.openai.azure.com/openai/deployments/<name>/embeddings?api-version=<version>;impersonate).",
					"password": false
				},
				{
					"id": "kusto_known_services_json",
					"type": "promptString",
					"description": "JSON array of preconfigured Kusto services (e.g., [{\"service_uri\":\"https://cluster.kusto.windows.net\",\"default_database\":\"DB\"}]).",
					"password": false
				},
				{
					"id": "kusto_eager_connect",
					"type": "promptString",
					"description": "Whether to eagerly connect to the default service on startup (true/false).",
					"password": false
				},
				{
					"id": "kusto_allow_unknown_services",
					"type": "promptString",
					"description": "Allow connections to services not listed in KUSTO_KNOWN_SERVICES (true/false).",
					"password": false
				},
				{
					"id": "fabric_api_base",
					"type": "promptString",
					"description": "Base URL for Fabric APIs (default https://api.fabric.microsoft.com/v1).",
					"password": false
				}
			]
		},
		"fabricStudio.workspaceFilter": "review",
		"powerbi.workspaceFilter": "invoice"
	}
}